            "reranker = CrossEncoder('cross-encoder/ms-marco-MiniLM-L-6-v2')\n",
            "\n",
            "def retrieve_with_rerank(query, base_retriever, k_initial=20, top_n=5):\n",
            "    # 1. Recuperar k_initial candidatos usando k-NN (ChromaDB)\n",
            "    total_vectors = base_retriever.vectorstore._collection.count()\n",
            "    k_to_retrieve = min(k_initial, total_vectors)\n",
            "    \n",
            "    original_search_kwargs = base_retriever.search_kwargs\n",
            "    base_retriever.search_kwargs = {'k': k_to_retrieve}\n",
            "    candidates = base_retriever.invoke(query)\n",
            "    base_retriever.search_kwargs = original_search_kwargs\n",
            "    \n",
            "    if not candidates:\n",
            "        return []\n",
            "        \n",
            "    # 2. Calcular scores del cross-encoder para el par (query, chunk)\n",
            "    pairs = [[query, doc.page_content] for doc in candidates]\n",
            "    scores = reranker.predict(pairs)\n",
            "    \n",
            "    # 3. Reordenar y quedarse con top_n\n",
            "    scored_candidates = list(zip(candidates, scores))\n",
            "    scored_candidates.sort(key=lambda x: x[1], reverse=True)\n",
            "    \n",
            "    return [doc for doc, score in scored_candidates[:top_n]]\n",

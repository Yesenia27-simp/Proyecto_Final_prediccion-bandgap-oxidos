# ── Mocks para Google ADK Agents (Representación de lo cubierto en la lección) ──
class FunctionTool:
    def __init__(self, func):
        self.func = func
        self.name = func.__name__

class LlmAgent:
    def __init__(self, name, model, instruction, tools=None):
        self.name = name
        self.model = model
        self.instruction = instruction
        self.tools = tools or []
        
    def run(self, input_text):
        print(f"  [{self.name} - ADK] Ejecutando con modelo '{self.model}'...")
        if self.tools:
            print(f"  [{self.name} - ADK] Llamando a tool: {self.tools[0].name}()")
            tool_res = self.tools[0].func(input_text)
            return f"Tool result: {tool_res}"
        return f"Generado reporte basado en: '{input_text}'"

class SequentialAgent:
    def __init__(self, name, agents):
        self.name = name
        self.agents = agents
        
    def run(self, input_text):
        print(f"[{self.name} - ADK Sequential] Iniciando pipeline de {len(self.agents)} agentes")
        current_input = input_text
        for agent in self.agents:
            current_input = agent.run(current_input)
            print(f"  -> Output intermedio transferido: {current_input}")
        return current_input

class AgentCard:
    def __init__(self, name, domain, skills):
        self.name = name
        self.domain = domain
        self.skills = skills
        
    def to_json(self):
        return json.dumps(self.__dict__, indent=2)

print("\n" + "="*70)
print("1. LlmAgent ADK con FunctionTool")
print("="*70)

def buscar_toxicidad_ocde(material: str) -> str:
    if "plata" in material.lower():
        return "Alta toxicidad acuática (OCDE 202/203)."
    return "Toxicidad moderada a baja."

tool_toxicidad = FunctionTool(buscar_toxicidad_ocde)

adk_agent_1 = LlmAgent(
    name="ToxAnalyzer_ADK",
    model="gemini-1.5-pro",
    instruction="Analiza la toxicidad ecotoxicológica del material provisto usando tus tools.",
    tools=[tool_toxicidad]
)
res_1 = adk_agent_1.run("nanopartículas de plata")
print(f"RESULTADO: {res_1}")

print("\n" + "="*70)
print("2. SequentialAgent de 2 sub-agentes (Pipeline ADK)")
print("="*70)
adk_agent_2 = LlmAgent(
    name="ReportWriter_ADK",
    model="gemini-1.5-pro",
    instruction="Genera un reporte corto basado en el análisis de toxicidad."
)

sequential_adk = SequentialAgent(
    name="EcotoxPipeline_ADK",
    agents=[adk_agent_1, adk_agent_2]
)
res_seq = sequential_adk.run("nanopartículas de plata")
print(f"RESULTADO FINAL SECUENCIAL: {res_seq}")



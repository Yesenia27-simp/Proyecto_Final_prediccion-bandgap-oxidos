class BudgetGuard:
    def __init__(self, budget_limit: float):
        self.budget_limit = budget_limit
        self.current_spend = 0.0
        self.fallback_active = False

    def check_and_charge(self, cost: float):
        self.current_spend += cost
        usage_pct = (self.current_spend / self.budget_limit) * 100
        print(f"[BudgetGuard] Gasto actual: ${self.current_spend:.2f} / ${self.budget_limit:.2f} ({usage_pct:.1f}%)")
        
        if usage_pct > 80.0 and not self.fallback_active:
            print("⚠️ [BudgetGuard ALERT] Gasto superior al 80%. Activando Fallback dinámico al modelo más barato (gemini-1.5-flash-8b).")
            self.fallback_active = True
            
        if self.current_spend > self.budget_limit:
            print("❌ [BudgetGuard ALERT] LÍMITE SUPERADO. Transacción A2A denegada.")
            return False
        return True

# Función que simula un nodo en LangGraph actuando como Cliente A2A
def langgraph_client_a2a_call(input_data: str, guard: BudgetGuard):
    print("\n[LangGraph Client Node] Iniciando llamada RPC (A2A) al Servidor ADK...")
    
    # Determinar el modelo dinámicamente según el estado del guard
    current_model = "gemini-1.5-pro" if not guard.fallback_active else "gemini-1.5-flash-8b"
    cost_per_call = 0.80 if current_model == "gemini-1.5-pro" else 0.05
    
    print(f"[LangGraph Client Node] Modelo negociado: {current_model} | Costo estimado: ${cost_per_call}")
    
    # Inyectar el modelo dinámico en el agente ADK (simulando paso de parámetros en A2A request)
    sequential_adk.agents[0].model = current_model
    sequential_adk.agents[1].model = current_model
    
    if not guard.check_and_charge(cost_per_call):
        return "Ejecución denegada."
        
    return sequential_adk.run(input_data)

# Simulación de ráfaga de peticiones para agotar el presupuesto
guard = BudgetGuard(budget_limit=2.0)
for i in range(1, 5):
    print(f"\n--- Petición A2A #{i} ---")
    langgraph_client_a2a_call("nanopartículas de plata", guard)


print("\n" + "="*70)
print("5. Tres Diferencias Clave entre ADK y LangGraph")
print("="*70)
print("1. Arquitectura y Flujo de Control:")
print("   - LangGraph: Basado en grafos de estado (StateGraph) con nodos y aristas cíclicas, ideal para lógicas no lineales, bucles de corrección y estados complejos.")
print("   - ADK: Enfoque más declarativo y jerárquico (LlmAgent, SequentialAgent, ConcurrentAgent), ideal para pipelines estructurados y rígidos.")
print("\n2. Ecosistema y Exposición A2A:")
print("   - ADK: Optimizado de forma nativa para Vertex AI y la comunicación Agent-to-Agent (A2A) sobre RPC, facilitando que los agentes se comporten como microservicios en Google Cloud.")
print("   - LangGraph: Ecosistema agnóstico a la nube que utiliza LangServe y REST estándar, más generalista para integraciones de código abierto.")
print("\n3. Persistencia de Memoria y Checkpointing:")
print("   - LangGraph: Implementa 'Checkpointers' (ej. SQLite, Postgres) integrados directamente en el grafo, permitiendo Time-Travel y Human-in-the-Loop.")
print("   - ADK: Delega el manejo de estado y sesiones a servicios externos administrados (como SessionService), acoplando la persistencia a la infraestructura de Google.")

import json

notebook_path = "U5_05_RAG_MEMORIA_AVANZADA.ipynb"
with open(notebook_path, "r", encoding="utf-8") as f:
    data = json.load(f)

cells = data.get("cells", [])
output = []
output.append(f"Total cells: {len(cells)}")
for i, cell in enumerate(cells[-15:]):
    idx = len(cells) - 15 + i
    source = "".join(cell.get("source", []))
    output.append(f"\n--- Cell {idx} ({cell.get('cell_type')}) ---")
    output.append(source[:500] + ("..." if len(source) > 500 else ""))

with open("notebook_structure.txt", "w", encoding="utf-8") as out:
    out.write("\n".join(output))

print("Structure written successfully!")

# ── PASO 6: Hiperparámetros justificados para Ciberseguridad ──────────────────
#
# temperature = 0.0
#   JUSTIFICACIÓN: En análisis forense, un mismo CVE debe producir SIEMPRE el mismo
#   nivel de severidad. Temperature > 0 podría generar "ALTO" en una ejecución y
#   "MEDIO" en otra para el mismo input — inaceptable en un informe de incidente
#   que puede tener implicaciones legales o regulatorias (ISO 27001, NIS2, SOC2).
#
# top_p = 0.1
#   JUSTIFICACIÓN: Restringir al 10% más probable del vocabulario fuerza al modelo
#   a usar terminología técnica estándar (CVSS, IoC, APT, TTP, lateral movement).
#   Evita sinónimos informales ("hackeo", "piratería") que desacreditarían un informe
#   ante un CISO o auditor. En dominios creativos top_p alto es deseable; en
#   seguridad informática la precisión semántica es no negociable.
#
# frequency_penalty = 0.3
#   JUSTIFICACIÓN: Valor moderado. Evita que el agente repita el mismo párrafo de
#   advertencia ("se recomienda parchado inmediato") en cada sección del informe.
#   No se eleva a 1.0 porque términos como "vulnerabilidad", "CVSS", "parche" DEBEN
#   aparecer varias veces en un informe técnico y no deben ser penalizados.
#
# max_tokens = 800
#   JUSTIFICACIÓN: Un informe de incidente bien escrito no supera media página (~600 palabras):
#   descripción (100), clasificación CVSS (50), IoCs (100), SLA (50), acciones (200),
#   referencias (100). Limitar tokens previene respuestas infladas con relleno y reduce
#   el riesgo de alucinaciones en contenido técnico extenso.

CYBER_HYPERPARAMS = {
    "temperature": 0.0,        # Determinismo total — reproducibilidad forense
    "top_p": 0.1,              # Léxico técnico de seguridad — precisión semántica
    "frequency_penalty": 0.3,  # Evita repetición de párrafos sin penalizar términos clave
    "max_tokens": 800,         # Informe conciso — reduce alucinaciones en texto largo
}

print("\n" + "=" * 60)

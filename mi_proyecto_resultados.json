@tool
def consultar_cve(cve_id: str) -> str:
    """Consulta la base de datos NVD simulada para obtener descripción y CVSS de un CVE.
    Usala cuando el usuario mencione un identificador CVE (ej: CVE-2021-44228).
    Args: cve_id (str): Identificador en formato CVE-YYYY-NNNNN.
    Returns: Descripción técnica, puntaje CVSS v3.1 y vector de ataque."""
    # OWASP: Sanitización — evitar path traversal y prompt injection
    safe_id = cve_id.strip().upper().replace("/", "").replace("..", "")
    nvd = {
        "CVE-2021-44228": (
            "Log4Shell — RCE en Apache Log4j 2 via JNDI lookup. "
            "CVSS v3.1: 10.0 (CRITICO). Afecta Log4j 2.0-beta9 a 2.14.1. "
            "Vector: AV:N/AC:L/PR:N/UI:N/S:C/C:H/I:H/A:H. Parche: 2.17.1+."
        ),
        "CVE-2023-0669": (
            "GoAnywhere MFT — Deserializacion insegura pre-auth que permite RCE. "
            "CVSS v3.1: 9.8 (CRITICO). Explotada activamente por ransomware Cl0p. "
            "Vector: AV:N/AC:L/PR:N/UI:N/S:U/C:H/I:H/A:H. Parche: 7.1.2+."
        ),
        "CVE-2024-3400": (
            "PAN-OS GlobalProtect — Inyeccion de comandos OS en gateway VPN Palo Alto. "
            "CVSS v3.1: 10.0 (CRITICO). Explotada como zero-day (Operacion MidnightEclipse). "
            "Vector: AV:N/AC:L/PR:N/UI:N/S:C/C:H/I:H/A:H. Parche: inmediato requerido."
        ),
        "CVE-2022-30190": (
            "Follina (MSDT) — Ejecucion de codigo via archivos Office sin macros. "
            "CVSS v3.1: 7.8 (ALTO). Explota el protocolo ms-msdt://. "
            "Vector: AV:L/AC:L/PR:N/UI:R/S:U/C:H/I:H/A:H. Parche: MS KB5014699."
        ),
    }
    r = nvd.get(safe_id)
    if r:
        return f"[NVD] {safe_id}: {r}"
    return (
        f"CVE '{safe_id}' no encontrado en la DB local. "
        "Consulta https://nvd.nist.gov para datos actualizados."
    )


@tool
def calcular_cvss_severidad(puntuacion: float) -> str:
    """Clasifica un puntaje CVSS v3.x en nivel de severidad oficial NIST/FIRST
    y genera el SLA de respuesta recomendado.
    Usala cuando tengas un numero CVSS (0.0-10.0) y necesites priorizar la respuesta.
    Args: puntuacion (float): Puntaje CVSS entre 0.0 y 10.0.
    Returns: Nivel de severidad, SLA y accion recomendada."""
    score = float(puntuacion)
    if not (0.0 <= score <= 10.0):
        return "Error: el puntaje CVSS debe estar entre 0.0 y 10.0."
    if score == 0.0:
        nivel, sla, accion = "NINGUNO", "N/A", "Sin impacto conocido. Monitoreo pasivo."
    elif score <= 3.9:
        nivel, sla, accion = "BAJO", "90 dias", "Incluir en el proximo ciclo de parchado."
    elif score <= 6.9:
        nivel, sla, accion = "MEDIO", "30 dias", "Parchado planificado con prioridad moderada."
    elif score <= 8.9:
        nivel, sla, accion = "ALTO", "7 dias", "Parchado urgente. Verificar exposicion perimetral."
    else:
        nivel, sla, accion = (
            "CRITICO", "24-48 horas",
            "Respuesta INMEDIATA: aislar sistemas afectados, aplicar mitigacion temporal, "
            "notificar al CERT y activar el Plan de Respuesta a Incidentes."
        )
    return (
        f"CVSS {score:.1f} | Severidad: {nivel} | SLA: {sla}\n"
        f"Accion: {accion}"
    )


@tool
def clasificar_ioc(indicador: str) -> str:
    """Clasifica un Indicador de Compromiso (IoC) y lo valida contra la base de
    inteligencia de amenazas (hashes malware, IPs C2, dominios phishing).
    Usala cuando el usuario proporcione un hash MD5/SHA256, IP sospechosa o dominio.
    Args: indicador (str): Hash, IP, dominio o URL a analizar.
    Returns: Tipo de IoC, veredicto (MALICIOSO/LIMPIO/DESCONOCIDO) y contexto."""
    safe_ioc = indicador.strip().lower()[:256]  # OWASP: truncar — anti-DoS
    ioc_db = {
        "44d88612fea8a8f36de82e1278abb02f": "HASH MD5 | MALICIOSO — Eicar test file.",
        "e3b0c44298fc1c149afbf4c8996fb924": "HASH SHA256 | LIMPIO — Archivo vacio (0 bytes).",
        "185.220.101.1": (
            "IP | MALICIOSO — Nodo Tor usado como C2 por campanas ransomware. "
            "Bloquear en firewall. Fuente: Emerging Threats."
        ),
        "45.142.212.100": (
            "IP | MALICIOSO — C2 del grupo Lazarus (APT38-DPRK). "
            "Asociado a robo de credenciales bancarias. Aislar y reportar al CERT."
        ),
        "evil-update.com": (
            "DOMINIO | MALICIOSO — Phishing que suplanta Windows Update. "
            "Distribuye infostealer Raccoon v2."
        ),
        "log4j.binario.xyz": (
            "DOMINIO | MALICIOSO — Servidor JNDI para exfiltracion via Log4Shell (CVE-2021-44228)."
        ),
    }
    r = ioc_db.get(safe_ioc)
    if r:
        return f"[Threat Intel] '{indicador}': {r}"
    # Heuristica de tipo si no esta en la DB
    if len(safe_ioc) in (32, 40, 64, 128):
        tipo = "HASH"
    elif safe_ioc.replace(".", "").isdigit() or ":" in safe_ioc:
        tipo = "IP"
    elif "." in safe_ioc and "/" not in safe_ioc:
        tipo = "DOMINIO"
    else:
        tipo = "URL"
    return (
        f"[Threat Intel] '{indicador}' | Tipo: {tipo} | Veredicto: DESCONOCIDO. "
        "No en la DB local. Verificar en VirusTotal, AlienVault OTX o MISP."
    )


tools_cyber = [consultar_cve, calcular_cvss_severidad, clasificar_ioc]
print("Tools definidas:", [t.name for t in tools_cyber])



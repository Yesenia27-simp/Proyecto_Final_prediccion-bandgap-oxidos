    "# ============================================================\n",
    "#   [ESTUDIANTE] SECCION 1.1: CARGA DE DATOS\n",
    "#   Reemplaza el bloque de ejemplo con tu codigo de carga\n",
    "# ============================================================\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# Generación de dataset sintético coherente para band gaps de óxidos metálicos\n",
    "# para celdas solares, garantizando que el proyecto corra inmediatamente sin API Keys.\n",
    "np.random.seed(42)\n",
    "n_samples = 250\n",
    "\n",
    "# Fórmulas de óxidos de referencia común\n",
    "formulas_oxidos = ['TiO2', 'ZnO', 'SnO2', 'Fe2O3', 'Al2O3', 'Cu2O', 'NiO', 'WO3', 'Bi2O3', 'SiO2', \n",
    "                   'ZrO2', 'Ta2O5', 'Nb2O5', 'V2O5', 'Cr2O3', 'MnO2', 'Co3O4', 'CuO', 'In2O3', 'PbO']\n",
    "\n",
    "formulas = np.random.choice(formulas_oxidos, n_samples)\n",
    "electroneg_metal = np.random.uniform(1.2, 2.2, n_samples)\n",
    "electroneg_diff = 3.44 - electroneg_metal\n",
    "density = np.random.uniform(3.5, 7.5, n_samples)\n",
    "coord_num = np.random.choice([4, 6, 8], n_samples)\n",
    "\n",
    "# Modelo físico simple de bandgap con ruido\n",
    "bandgap = 1.85 * electroneg_diff - 0.25 * density + np.random.normal(0, 0.25, n_samples)\n",
    "bandgap = np.clip(bandgap, 0.5, 6.5)  # Restringir bandgaps a rangos reales de óxidos\n",
    "\n",
    "df = pd.DataFrame({\n",
    "    'formula': formulas,\n",
    "    'electroneg_metal': electroneg_metal,\n",
    "    'electroneg_diff': electroneg_diff,\n",
    "    'density': density,\n",
    "    'coord_num': coord_num,\n",
    "    'bandgap': bandgap\n",
    "})\n",
    "\n",
    "# Guardamos copia local en formato CSV para mayor realismo y persistencia\n",
    "csv_path = \"dataset_bandgap_oxidos.csv\"\n",
    "df.to_csv(csv_path, index=False)\n",
    "print(f\"Cargados {len(df)} registros para predicción de band gap en óxidos.\")\n",
    "\n",
    "# CHECKPOINT 1 — La celda siguiente valida esta seccion\n",
    "_checkpoint_1_ok = df is not None and isinstance(df, pd.DataFrame) and len(df) > 0\n",
    "\n"
   ]

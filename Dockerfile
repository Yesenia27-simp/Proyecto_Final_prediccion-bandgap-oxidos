    "# ============================================================\n",
    "#   SECCION 5B: AGENTE LangGraph con tools reales\n",
    "#   Requiere al menos una API key o Ollama corriendo\n",
    "# ============================================================\n",
    "import sys\n",
    "import types\n",
    "import joblib\n",
    "\n",
    "# Guard: si torch no puede inicializar su DLL (WinError 1114 en Windows), stubbeamos\n",
    "try:\n",
    "    import torch\n",
    "    _torch_ok = True\n",
    "except OSError:\n",
    "    _torch_ok = False\n",
    "    for _mod in [\n",
    "        \"torch\", \"torch.nn\", \"torch.optim\", \"torch.utils\", \"torch.utils.data\",\n",
    "        \"transformers\", \"transformers.modeling_utils\",\n",
    "    ]:\n",
    "        if _mod not in sys.modules:\n",
    "            sys.modules[_mod] = types.ModuleType(_mod)\n",
    "\n",
    "from langchain_core.tools import tool as lc_tool\n",
    "from langgraph.prebuilt import create_react_agent\n",
    "\n",
    "# Guardar el modelo entrenado y el scaler en disco para cargarlos en la tool\n",
    "joblib.dump(model, \"modelo_bandgap.pkl\")\n",
    "joblib.dump(scaler, \"scaler_bandgap.pkl\")\n",
    "\n",
    "# Definir herramientas adaptadas para nuestro dominio de celdas solares\n",
    "@lc_tool\n",
    "def model_bandgap_predictor(electroneg_metal: float, density: float, coord_num: float) -> str:\n",
    "    \"\"\"Predice el band gap de un óxido metálico basado en descriptores químicos y geométricos.\n",
    "    electroneg_metal: Electronegatividad del metal.\n",
    "    density: Densidad del óxido en g/cm³.\n",
    "    coord_num: Número de coordinación promedio del metal (usualmente 4, 6 u 8).\n",
    "    \"\"\"\n",
    "    try:\n",
    "        clf = joblib.load(\"modelo_bandgap.pkl\")\n",
    "        scl = joblib.load(\"scaler_bandgap.pkl\")\n",
    "        diff = 3.44 - electroneg_metal\n",
    "        features = np.array([[electroneg_metal, diff, density, coord_num]])\n",
    "        features_scaled = scl.transform(features)\n",
    "        pred = clf.predict(features_scaled)[0]\n",
    "        return f\"El band gap estimado para el óxido metálico es: {pred:.3f} eV\"\n",
    "    except Exception as e:\n",
    "        return f\"Error al ejecutar predicción: {e}\"\n",
    "\n",
    "@lc_tool\n",
    "def literature_search(query: str) -> str:\n",
    "    \"\"\"Busca papers relevantes en la base de conocimiento de óxidos y celdas solares.\"\"\"\n",
    "    papers = tool_consultar_literatura(query)\n",
    "    return \"\\n\".join(f\"[{p['score']:.2f}] {p['titulo']}\" for p in papers)\n",
    "\n",
    "tools_proyecto = [model_bandgap_predictor, literature_search]\n",
    "\n",
    "# Crear y ejecutar el agente\n",
    "llm = get_llm()\n",
    "\n",
    "if llm is not None:\n",
    "    agente = create_react_agent(llm, tools_proyecto)\n",

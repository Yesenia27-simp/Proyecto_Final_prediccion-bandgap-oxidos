    "# ============================================================\n",
    "#   [ESTUDIANTE] SECCION 4: EVALUACION\n",
    "#   Calcula las metricas de tu criterio de exito\n",
    "# ============================================================\n",
    "from sklearn.metrics import mean_squared_error, r2_score\n",
    "\n",
    "# Calcular predicciones y métricas\n",
    "y_pred = model.predict(X_test)\n",
    "r2 = r2_score(y_test, y_pred)\n",
    "mse = mean_squared_error(y_test, y_pred)\n",
    "\n",
    "# Registrar resultados\n",
    "mis_resultados = {\n",
    "    \"metrica_nombre\": \"R2_score\",\n",
    "    \"metrica_valor\": round(r2, 4),\n",
    "    \"umbral_exito\": 0.85,\n",
    "    \"objetivo_superado\": r2 >= 0.85,\n",
    "    \"notas\": f\"El modelo alcanzó un R² de {r2:.4f} y un MSE de {mse:.4f}. Supera el umbral de éxito del 0.85 establecido.\",\n",
    "}\n",
    "\n",
    "print(\"MÉTRICAS DEL PROYECTO:\")\n",
    "print(\"-\" * 30)\n",
    "for k, v in mis_resultados.items():\n",
    "    print(f\"  {k:18}: {v}\")\n",
    "\n",
    "_checkpoint_4_ok = len(mis_resultados) > 0 and mis_resultados[\"metrica_valor\"] is not None\n",
    "print(\"\\nCheckpoint 4:\", \"OK\" if _checkpoint_4_ok else \"FALLÓ\")\n",

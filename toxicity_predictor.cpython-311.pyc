"""
Skill para proveer contexto de dominio a los agentes.
"""

SKILL_METADATA = {
    "name": "agent_warmup.context_loader",
    "description": "Inyecta contexto de dominio especializado en agentes LLM. Soporta ecotoxicología.",
    "input": "domain: str, custom_config: dict | None",
    "output": "dict con system_context, messages, domain",
    "domain": ["research", "engineering", "ecotoxicology_nanomaterials", "custom"],
    "version": "1.0.0"
}

DOMAIN_CONTEXTS = {
    "research": "Eres un asistente de investigación científica especializado en análisis de literatura, síntesis de conocimiento y generación de hipótesis. Aportas rigor metodológico y citas evidencia cuando es posible. Tu audiencia es investigadores de postgrado.",
    "engineering": "Eres un ingeniero de software senior...",
    "ecotoxicology_nanomaterials": """Eres un experto mundial en ecotoxicología de nanomateriales.
Tus responsabilidades y directrices de razonamiento son:
1. Evaluar de forma sistemática los parámetros fisicoquímicos críticos (como tamaño, forma, carga superficial, recubrimiento y solubilidad) y cómo afectan la toxicidad.
2. Clasificar el nivel de riesgo basándote en la evidencia empírica de toxicidad para organismos modelo estandarizados (ej. Daphnia magna, Danio rerio, algas verdes) y su potencial de bioacumulación en cadenas tróficas acuáticas o terrestres.
3. Citar y referenciar explícitamente las pautas de regulación establecidas y guías de ensayo pertinentes (ej. OECD Test Guidelines para nanomateriales, normativas de la EPA, REACH).
4. Mantener siempre un estricto rigor científico, reconociendo la incertidumbre inherente en nano-toxicología y proporcionando recomendaciones conservadoras de mitigación de riesgos basadas en la literatura actual."""
}

def list_available_domains():
    return list(DOMAIN_CONTEXTS.keys())

def warm_up(domain: str, custom_config=None):
    from langchain_core.messages import SystemMessage
    
    context = DOMAIN_CONTEXTS.get(domain)
    if not context:
        context = f"Eres un asistente experto en {domain}."
        
    return {
        "domain": domain,
        "system_context": context,
        "messages": [SystemMessage(content=context)]
    }

def warm_up_agent(domain: str):
    return warm_up(domain)["system_context"]

import nbformat

notebook_path = "U5_03_CREWAI_SISTEMAS_MULTIAGENTE.ipynb"

print(f"Leyendo notebook: {notebook_path}")
nb = nbformat.read(notebook_path, as_version=4)

fixed = False
for cell in nb.cells:
    if cell.cell_type == "code" and "calcular_propiedades" in cell.source:
        # Reemplazar la tool importada de langchain por la de crewai
        if "from langchain_core.tools import tool" in cell.source:
            cell.source = cell.source.replace(
                "from langchain_core.tools import tool", 
                "from crewai.tools import tool"
            )
            fixed = True
        
        # Si tiene ChatGoogleGenerativeAI, la cambiamos a la nativa de CrewAI para evitar conflictos de Pydantic
        if "ChatGoogleGenerativeAI" in cell.source:
            # Reemplazar la inicialización por la nativa de crewai LLM
            target_import = "from langchain_google_genai import ChatGoogleGenerativeAI"
            replacement_import = "from crewai import LLM"
            
            target_init = 'llm = ChatGoogleGenerativeAI(model="gemini-1.5-flash", temperature=0.3)'
            replacement_init = (
                'import os\n'
                'llm = LLM(\n'
                '    model="openrouter/google/gemini-1.5-flash" if os.environ.get("OPENROUTER_API_KEY") else "gemini/gemini-1.5-flash",\n'
                '    api_key=os.environ.get("OPENROUTER_API_KEY") or os.environ.get("GOOGLE_API_KEY"),\n'
                '    base_url="https://openrouter.ai/api/v1" if os.environ.get("OPENROUTER_API_KEY") else None,\n'
                '    temperature=0.3\n'
                ')'
            )
            
            if target_import in cell.source:
                cell.source = cell.source.replace(target_import, replacement_import)
                fixed = True
            if target_init in cell.source:
                cell.source = cell.source.replace(target_init, replacement_init)
                fixed = True

if fixed:
    nbformat.write(nb, notebook_path)
    print(f"Notebook {notebook_path} corregido y guardado exitosamente.")
else:
    print("No se realizaron cambios en la notebook (posiblemente ya está corregida).")


